54","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"255","messages":"256","suppressedMessages":"257","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"258","messages":"259","suppressedMessages":"260","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"261","messages":"262","suppressedMessages":"263","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"264","messages":"265","suppressedMessages":"266","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"267","messages":"268","suppressedMessages":"269","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"270","messages":"271","suppressedMessages":"272","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"273","messages":"274","suppressedMessages":"275","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\index.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\App.js",["276","277","278"],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\reportWebVitals.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\About.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\Home.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\ContactUs.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\Jewelry.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\Buttons.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\ProductDetail.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\AccessoryTypeFilter.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\hooks\\useProducts.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\services\\productService.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\jewelry-shop\\src\\services\\goldPriceService.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\index.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\reportWebVitals.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\App.js",["279","280","281"],[],"import React, { useEffect, useState } from \"react\";\r\nimport { BrowserRouter as Router, Routes, Route, Link } from \"react-router-dom\";\r\nimport Home from \"./Home.js\";\r\nimport About from \"./About.js\";\r\nimport ContactUs from \"./ContactUs.js\";\r\nimport ProductDetail from \"./ProductDetail.js\";\r\nimport \"./App.css\";\r\n\r\nfunction App() {\r\n  const [theme, setTheme] = useState(() => {\r\n    if (typeof window === \"undefined\") return \"light\";\r\n    const stored = window.localStorage.getItem(\"theme\");\r\n    return stored === \"dark\" ? \"dark\" : \"light\";\r\n  });\r\n\r\n  useEffect(() => {\r\n    document.body.setAttribute(\"data-theme\", theme);\r\n    window.localStorage.setItem(\"theme\", theme);\r\n  }, [theme]);\r\n\r\n  const toggleTheme = () => {\r\n    setTheme((prev) => (prev === \"dark\" ? \"light\" : \"dark\"));\r\n  };\r\n\r\n  return (\r\n    <Router>\r\n      <nav className=\"nav\">\r\n        <div className=\"brand\">Aung Myay Treasure</div>\r\n        <button\r\n          type=\"button\"\r\n          className=\"theme-toggle\"\r\n          onClick={toggleTheme}\r\n          aria-label=\"Toggle dark mode\"\r\n        >\r\n          <span className=\"toggle-label\">{theme === \"dark\" ? \"Light\" : \"Dark\"} mode</span>\r\n          <span className={`toggle-chip ${theme === \"dark\" ? \"is-dark\" : \"\"}`}></span>\r\n        </button>\r\n        <div className=\"nav-links\">\r\n          <Link to=\"/\" className=\"link\">\r\n            Home\r\n          </Link>\r\n          <Link to=\"/about\" className=\"link\">\r\n            About\r\n          </Link>\r\n          <Link to=\"/contactus\" className=\"link\">\r\n            Contact\r\n          </Link>\r\n        </div>\r\n      </nav>\r\n\r\n      <Routes>\r\n        <Route path=\"/\" element={<Home />} />\r\n        <Route path=\"/about\" element={<About />} />\r\n        <Route path=\"/contactus\" element={<ContactUs />} />\r\n        <Route path=\"/product/:id\" element={<ProductDetail />} />\r\n      </Routes>\r\n\r\n      <footer className=\"footer\">\r\n        <div className=\"footer-inner\">\r\n          <div className=\"footer-brand\">\r\n            <p className=\"footer-logo\">Aung Myay Treasure</p>\r\n            <p className=\"footer-copy\">\r\n              Fine gold, diamond, and heritage jewellery curated in Myanmar. Walk in or message us to reserve.\r\n            </p>\r\n          </div>\r\n\r\n          <div className=\"footer-group\">\r\n            <p className=\"footer-title\">Explore</p>\r\n            <Link to=\"/\" className=\"footer-link\">Home</Link>\r\n            <Link to=\"/about\" className=\"footer-link\">About</Link>\r\n            <Link to=\"/contactus\" className=\"footer-link\">Contact</Link>\r\n          </div>\r\n\r\n          <div className=\"footer-group\">\r\n            <p className=\"footer-title\">Visit & Call</p>\r\n            <p className=\"footer-text\">Yangon & Mandalay showrooms</p>\r\n            <p className=\"footer-text\">Phone: +95 9 000 000 000</p>\r\n            <p className=\"footer-text\">Email: hello@aungstargold.com</p>\r\n          </div>\r\n\r\n          <div className=\"footer-group\">\r\n            <p className=\"footer-title\">Follow</p>\r\n            <a className=\"footer-link\" href=\"#\" aria-label=\"Facebook\">Facebook</a>\r\n            <a className=\"footer-link\" href=\"#\" aria-label=\"Instagram\">Instagram</a>\r\n            <a className=\"footer-link\" href=\"#\" aria-label=\"Viber\">Viber</a>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"footer-bottom\">\r\n          <p className=\"footer-bottom-text\">&copy; {new Date().getFullYear()} Aung Myay Treasure. Crafted with care.</p>\r\n        </div>\r\n      </footer>\r\n    </Router>\r\n  );\r\n}\r\n\r\nexport default App;\r\n","D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\ProductDetail.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\About.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\Home.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\ContactUs.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\AccessoryTypeFilter.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\Jewelry.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\Buttons.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\services\\productService.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\services\\goldPriceService.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\services\\api.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\hooks\\useProducts.js",[],[],"D:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\config\\apiConfig.js",[],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\index.js",[],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\reportWebVitals.js",[],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\App.js",["282","283","284"],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\About.js",[],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\Home.js",[],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\ProductDetail.js",[],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\ContactUs.js",[],[],"d:\\1111ICTInternship\\AungStarGoldMarket\\test\\src\\services\\api.